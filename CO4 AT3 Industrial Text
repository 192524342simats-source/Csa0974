Patient Name: Divya
Total Bill: Rs.17500.0
2. Airline Ticket Reservation System
Develop a Java program for an airline reservation system using Class and Objects.
Data Members:
• Passenger ID 
• Passenger Name 
• Flight Number 
• Ticket Fare 
• Number of Tickets 
Methods:
1. Read passenger details. 
2. Calculate total ticket cost. 
3. Apply a 5% discount if more than 5 tickets are booked. 
4. Display booking and payment details. 
Note: GST = 12% on the final amount.
import java.util.Scanner;

class Airline {
    int pid, tickets;
    String name, flightNo;
    double fare, total;

    void read() {
        Scanner sc = new Scanner(System.in);

        System.out.print("Passenger ID: ");
        pid = sc.nextInt();
        sc.nextLine();

        System.out.print("Passenger Name: ");
        name = sc.nextLine();

        System.out.print("Flight Number: ");
        flightNo = sc.nextLine();

        System.out.print("Ticket Fare: ");
        fare = sc.nextDouble();

        System.out.print("Number of Tickets: ");
        tickets = sc.nextInt();
    }

    void calculate() {
        total = fare * tickets;

        if (tickets > 5)
            total = total - (total * 0.05);

        total = total + (total * 0.12);
    }

    void display() {
        System.out.println("\nTotal Amount = Rs." + total);
    }

    public static void main(String[] args) {
        Airline a = new Airline();
        a.read();
        a.calculate();
        a.display();
    }
}
