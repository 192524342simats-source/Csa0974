4. Electricity Bill Management
Design a Java class to represent a consumer.
Data Members:
• Consumer Number 
• Consumer Name 
• Type of Connection (Domestic/Commercial) 
• Units Consumed 
Methods:
1. Read consumer details. 
2. Calculate electricity bill. 
3. Display bill amount. 
4. Validate connection type. 
Assume:
• Domestic: ₹5 per unit 
• Commercial: ₹8 per unit
import java.util.Scanner;

class Electricity {
    int consumerNo, units;
    String name, type;
    double bill;

    void readDetails() {
        Scanner sc = new Scanner(System.in);

        System.out.print("Enter Consumer Number: ");
        consumerNo = sc.nextInt();
        sc.nextLine();

        System.out.print("Enter Consumer Name: ");
        name = sc.nextLine();

        System.out.print("Enter Connection Type (Domestic/Commercial): ");
        type = sc.nextLine();

        System.out.print("Enter Units Consumed: ");
        units = sc.nextInt();
    }

    void calculateBill() {
        if (type.equalsIgnoreCase("Domestic"))
            bill = units * 5;
        else if (type.equalsIgnoreCase("Commercial"))
            bill = units * 8;
        else
            System.out.println("Invalid Connection Type");
    }

    void display() {
        System.out.println("\nConsumer Number: " + consumerNo);
        System.out.println("Consumer Name: " + name);
        System.out.println("Bill Amount: Rs." + bill);
    }

    public static void main(String args[]) {
        Electricity e = new Electricity();
        e.readDetails();
        e.calculateBill();
        e.display();
    }
}
